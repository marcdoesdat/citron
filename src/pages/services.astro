---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: 'Portrait',
    price: '199$',
    description: 'Séance individuelle ou en famille, en studio ou en extérieur.',
    icon: 'portrait',
    featured: true,
    ctaLabel: 'Réserver ma séance',
    features: [
      '1h à 1h30 de séance photo',
      '25 photos retouchées en haute résolution',
      'Galerie en ligne privée pendant 30 jours',
      'Impression A4 offerte',
    ],
  },
  {
    title: 'Événementiel',
    price: '299$',
    description: 'Couverture de vos événements professionnels et privés.',
    icon: 'event',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Jusqu\'à 3h de couverture',
      '80 photos retouchées en haute résolution',
      'Livraison sous 72h',
      'Galerie en ligne privée pendant 60 jours',
    ],
  },
  {
    title: 'Mariage',
    price: 'Sur demande',
    showStartingFrom: false,
    description: 'Couverture complète de votre plus beau jour, de la préparation à la soirée.',
    icon: 'wedding',
    featured: false,
    ctaLabel: 'Vérifier mes disponibilités',
    features: [
      'Journée complète (préparatifs inclus)',
      '300+ photos retouchées en haute résolution',
      'Album photo premium (20×20 cm)',
      'Séance engagement offerte (1h)',
      'Galerie en ligne pendant 12 mois',
    ],
  },
  {
    title: 'Corporatif',
    price: '399$',
    description: 'Photos professionnelles pour valoriser votre image de marque.',
    icon: 'corporate',
    featured: false,
    features: [
      '2h de séance en studio ou sur site',
      '40 photos retouchées en haute résolution',
      'Format adapté réseaux sociaux / LinkedIn',
      'Livraison sous 5 jours ouvrés',
    ],
  },
];

const faq = [
  {
    q: 'Quels sont les délais pour recevoir mes photos ?',
    a: 'Pour les séances portrait, vos photos vous seront livrées sous 5 à 7 jours ouvrables. Pour les mariages, prévoyez un délai de 3 à 4 semaines, le temps d\'accorder une attention minutieuse à la retouche de chaque cliché.',
  },
  {
    q: 'Vous déplacez-vous à l\'extérieur de Montréal ?',
    a: 'Oui ! Bien que je sois principalement actif dans la grande région de Montréal, je me déplace avec plaisir partout ailleurs, selon mes disponibilités. Des frais de kilométrage ou de déplacement peuvent s\'appliquer selon la distance.',
  },
  {
    q: 'Comment se déroule une séance portrait ?',
    a: 'Tout commence par une discussion pour bien cerner vos attentes et votre vision. La séance en elle-même dure généralement de 1h à 1h30, dans le lieu qui correspond le mieux à votre projet (en studio, en extérieur ou dans le confort de votre domicile).',
  },
  {
    q: 'Puis-je ajouter des filtres aux photos reçues ?',
    a: 'Chaque image que je vous livre est le résultat d\'un travail de retouche méticuleux qui reflète mon identité photographique. Afin de préserver cette intégrité artistique et la qualité optimale des images, je demande de ne pas appliquer de filtres supplémentaires (comme ceux d\'Instagram) par la suite.',
  },
];
---

<Layout
  title="Services & Tarifs"
  description="Forfaits photo à Montréal et sur la Rive-Nord — Portrait dès 199$, Événementiel dès 299$. Alex Diotte, photographe professionnel à Terrebonne et environs."
>

  <!-- En-tête -->
  <section class="py-20 px-6 text-center">
    <h1 class="font-serif text-5xl sm:text-6xl font-light tracking-[0.08em] text-neutral-900 mb-4">Services & Tarifs</h1>
    <p class="text-neutral-500 text-sm max-w-md mx-auto leading-relaxed">
      Des forfaits pensés pour chaque occasion, avec un seul objectif : créer des images qui vous ressemblent.
    </p>
  </section>

  <!-- Grille des forfaits -->
  <section class="px-6 pb-16 max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </section>

  <!-- Note sur les tarifs -->
  <div class="max-w-5xl mx-auto px-6 mb-16">
    <p class="text-sm text-slate-400 text-center border-t border-slate-100 pt-8">
      * Les tarifs ci-dessus sont à titre indicatif. Contactez-moi pour une soumission sur mesure.
    </p>
  </div>

  <!-- Section FAQ rapide -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-10 text-center">Questions fréquentes</h2>

      <div class="space-y-6">
        {faq.map(({ q, a }) => (
          <div class="border-b border-neutral-100 pb-6">
            <h3 class="font-medium text-neutral-900 mb-2">{q}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 text-center">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-4">
      Prêt·e à commencer ?
    </h2>
    <p class="text-neutral-500 text-sm mb-8 max-w-sm mx-auto">
      Décrivez votre projet et je vous répondrai dans les 24h avec une proposition sur mesure.
    </p>
    <a
      href="/contact"
      class="inline-block text-xs font-medium tracking-[0.18em] uppercase text-neutral-900 border-b border-neutral-900 pb-1 hover:text-neutral-500 hover:border-neutral-500 transition-colors"
    >
      Demander un devis gratuit
    </a>
  </section>

</Layout>
