---
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { Image } from 'astro:assets';

// Verticales (hauteur > largeur)
const portraitImages = [
  '/images/portfolio/DSC08557.jpg',
  '/images/portfolio/_DSC3143.jpg',
  '/images/portfolio/_DSC1428.jpg',
  '/images/portfolio/_DSC3964.jpg',
  '/images/portfolio/_DSC3942.jpg',
  '/images/portfolio/_DSC6843.jpg',
  '/images/portfolio/_DSC8007.jpg',
  '/images/portfolio/_CTN6791.jpg',
  '/images/portfolio/_CTN6835.jpg',
];

// Horizontales (largeur > hauteur)
const landscapeImages = [
  '/images/portfolio/_DSC3834.jpg',
  '/images/portfolio/_DSC5194.jpg',
  '/images/portfolio/_CTN5839.jpg',
  '/images/portfolio/_CTN6190.jpg',
  '/images/portfolio/_CTN6198.jpg',
  '/images/portfolio/_CTN6390.jpg',
  '/images/portfolio/_CTN7110.jpg',
  '/images/portfolio/_CTN7436.jpg',
  '/images/portfolio/_CTN8165.jpg',
  '/images/portfolio/_CTN8171.jpg',
  '/images/portfolio/_CTN8181.jpg',
  '/images/portfolio/_CTN8218.jpg',
  '/images/portfolio/_CTN8263.jpg',
];
---

<Layout
  title="Photographe Professionnelle"
  description="Alex Diotte, photographe professionnel à Montréal et sur la Rive-Nord (Terrebonne, Laval, Repentigny). Spécialisé en portrait et événementiel."
>

  <!-- ═══ HERO — Image pleine page ═══════════════════════════════════════ -->
  <section
    class="home-hero relative w-full overflow-hidden"
  >
    <Image
      src="/hero.jpg"
      alt="Portrait photographique par Alex Diotte"
      width={1920}
      height={1080}
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      class="home-hero-image absolute inset-0 w-full h-full object-cover"
      style="height: 100%;"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/88 via-black/42 to-transparent"></div>
    <!-- Contenu hero -->
    <div class="home-hero-copy absolute bottom-0 left-0 right-0 p-8 sm:p-14 text-white" style="padding-bottom: max(2rem, env(safe-area-inset-bottom));">
      <h1 class="font-serif text-3xl sm:text-5xl font-semibold leading-[1.05] tracking-[0.01em] max-w-md text-balance">
        Photographe et vidéaste à Montréal
      </h1>
      <p class="mt-3 text-sm sm:text-base text-white/85 max-w-xs leading-relaxed">
        Portraits et événements
      </p>
      <a
        href="/portfolio"
        class="flex w-fit mx-auto items-center justify-center mt-8 px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-white border border-white/90 rounded-sm min-h-11 hover:bg-white hover:text-neutral-900 active:bg-white active:text-neutral-900 active:border-white transition-colors duration-150"
      >
        Voir le portfolio
      </a>
    </div>
  </section>

  <!-- ═══ BIO ═════════════════════════════════════════════════════════════ -->
  <section class="relative z-10 bg-white py-12 md:py-24 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="overflow-hidden">
        <Image
          src="/images/portfolio/AlexDiotteBlackandWhite.jpg"
          alt="Alex Diotte, photographe professionnel"
          width={600}
          height={800}
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover"
        />
      </div>
      <div class="space-y-6">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 leading-tight">
          Bonjour, je suis<br/>Alex.
        </h2>
        <p class="text-neutral-500 leading-relaxed text-sm">
          <strong>Photographe et vidéaste depuis 2016</strong>, mon histoire avec l'image a commencé par un déclic lors d'un voyage à Cuba. Si la passion est née à ce moment-là, c'est en <strong>2020</strong> que j'ai fait le choix de m'y consacrer à <strong>100 %</strong>.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          J'ai d'abord forgé mon œil au cœur de la scène musicale. Immortaliser <strong>l'énergie brute</strong> des foules dans les soirées dubstep et riddim m'a appris l'essentiel : réagir en une fraction de seconde, gérer un environnement sous pression et capturer l'instant <strong>sur le vif</strong>, sans artifices. C'est cette agilité que j'apporte aujourd'hui sur chaque plateau.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Des événements corporatifs aux projets scolaires, en passant par les vidéos promotionnelles, ma mission est de capturer le vrai <em>vibe</em>. Mon approche est <strong>100 % adaptée à vos objectifs</strong> : je peux livrer un rendu <strong>épuré et hautement professionnel</strong>, tout comme je peux déployer une <strong>direction artistique audacieuse et assumée</strong> si vous souhaitez une image de marque qui sort du lot.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Que ce soit en coulisses, lors d'un grand événement ou dans un moment d'intimité, je crée des images qui racontent votre histoire avec une <strong>émotion authentique</strong>.
        </p>
        <a
          href="/portfolio"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Découvrir mon travail
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ APERÇU PORTFOLIO ════════════════════════════════════════════════ -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 mb-4">Portfolio</h2>
      </div>
      <div class="flex flex-wrap justify-center gap-6 px-2 mb-8">
        <button
          type="button"
          class="text-xs font-medium tracking-[0.18em] uppercase transition-colors duration-200 pb-1 text-amber-700 border-b border-amber-700"
          aria-pressed="true"
          data-preview-filter="all"
        >
          Tous
        </button>
        <button
          type="button"
          class="text-xs font-medium tracking-[0.18em] uppercase transition-colors duration-200 pb-1 text-neutral-500 hover:text-neutral-900"
          aria-pressed="false"
          data-preview-filter="portrait"
        >
          Portrait
        </button>
        <button
          type="button"
          class="text-xs font-medium tracking-[0.18em] uppercase transition-colors duration-200 pb-1 text-neutral-500 hover:text-neutral-900"
          aria-pressed="false"
          data-preview-filter="evenementiel"
        >
          Événementiel
        </button>
      </div>
      <div
        id="preview-gallery"
        class="preview-grid"
        data-portrait={JSON.stringify(portraitImages)}
        data-landscape={JSON.stringify(landscapeImages)}
      ></div>
      <div class="text-center mt-12">
        <a
          href="/portfolio"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Voir tout le portfolio
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ════════════════════════════════════════════════════════ -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 mb-4">Services & Tarifs</h2>
        <p class="text-neutral-500 text-sm max-w-md mx-auto">
          Des forfaits pensés pour chaque occasion.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        <div class="service-card-item border border-neutral-200 p-8 space-y-4 cursor-pointer transition-all duration-300">
          <h3 class="font-serif text-2xl font-light text-neutral-900">Portrait</h3>
          <div class="flex items-baseline gap-2">
            <p class="text-2xl font-bold text-neutral-900">199$</p>
            <span class="text-sm text-neutral-500">à partir de</span>
          </div>
          <p class="text-sm text-neutral-500">Séance individuelle ou en famille, en studio ou en extérieur.</p>
        </div>
        <div class="service-card-item border border-neutral-200 p-8 space-y-4 cursor-pointer transition-all duration-300">
          <h3 class="font-serif text-2xl font-light text-neutral-900">Événementiel</h3>
          <div class="flex items-baseline gap-2">
            <p class="text-2xl font-bold text-neutral-900">399$</p>
            <span class="text-sm text-neutral-500">à partir de</span>
          </div>
          <p class="text-sm text-neutral-500">Couverture de vos événements professionnels et privés.</p>
        </div>
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Voir tous les services
        </a>
      </div>
    </div>
  </section>

  <InstagramFeed posts={[
    'https://www.instagram.com/p/DN_CcZmjttY/?img_index=1',
    'https://www.instagram.com/p/DTjIqmUEX8x/?img_index=3',
    'https://www.instagram.com/p/DO9ivZYDNLo/?img_index=1',
  ]} />

  <!-- ═══ CTA FINAL ═══════════════════════════════════════════════════════ -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center space-y-6">
      <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900">
        Discutons de votre projet.
      </h2>
      <p class="text-neutral-500 text-sm leading-relaxed max-w-lg mx-auto">
        Un mariage, une séance portrait ou un événement à immortaliser ? Contactez-moi pour que nous imaginions ensemble les photos qui vous ressemblent.
      </p>
      <a
        href="/contact"
        class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
      >
        Prendre rendez-vous
      </a>
    </div>
  </section>


<style is:global>
  .home-hero-copy h1,
  .home-hero-copy p {
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.6);
  }

  .home-hero-image {
    object-position: 50% 42%;
  }

  .home-hero {
    height: calc(100dvh - var(--header-height, 64px));
  }

  @media (max-width: 767px) {
    .home-hero-image {
      object-position: 52% 28%;
    }

    .home-hero {
      height: 100dvh;
      margin-top: calc(var(--header-height, 64px) * -1);
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .home-hero-image {
      object-position: 52% 36%;
    }
  }

  @supports not (height: 100dvh) {
    .home-hero {
      height: calc(100vh - var(--header-height, 64px));
    }

    @media (max-width: 767px) {
      .home-hero {
        height: 100vh;
      }
    }
  }

  .preview-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    max-width: 38rem;
    margin: 0 auto;
  }

  .preview-grid-item {
    aspect-ratio: 4 / 5;
    overflow: hidden;
  }

  .service-card-item {
    position: relative;
    overflow: hidden;
  }

  .service-card-item::after {
    content: 'en savoir plus';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.85);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .service-card-item:hover::after,
  .service-card-item.active::after {
    opacity: 1;
  }
</style>

<script>
  const serviceCards = document.querySelectorAll<HTMLDivElement>('.service-card-item');
  serviceCards.forEach(card => {
    card.addEventListener('click', () => {
      window.location.href = '/services';
    });
    card.addEventListener('touchstart', () => {
      card.classList.add('active');
    });
    card.addEventListener('touchend', () => {
      setTimeout(() => card.classList.remove('active'), 300);
    });
  });

  const gallery = document.getElementById('preview-gallery');
  const previewFilterButtons = document.querySelectorAll<HTMLButtonElement>('[data-preview-filter]');

  if (gallery) {
    const shuffle = (arr: string[]) => [...arr].sort(() => Math.random() - 0.5);
    const portraitAll = JSON.parse(gallery.dataset.portrait || '[]');
    const landscapeAll = JSON.parse(gallery.dataset.landscape || '[]');

    const renderPreview = (filter: string) => {
      let selection: string[] = [];

      if (filter === 'portrait') {
        selection = shuffle(portraitAll).slice(0, 4);
      } else if (filter === 'evenementiel') {
        selection = shuffle(landscapeAll).slice(0, 4);
      } else {
        selection = shuffle([
          ...shuffle(portraitAll).slice(0, 2),
          ...shuffle(landscapeAll).slice(0, 2),
        ]).slice(0, 4);
      }

      gallery.innerHTML = selection.map(src => `
      <div class="preview-grid-item group">
        <img src="${src}" alt="Photo" loading="lazy" decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
      </div>
    `).join('');
    };

    previewFilterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const filter = button.dataset.previewFilter || 'all';

        previewFilterButtons.forEach((b) => {
          b.classList.remove('text-amber-700', 'border-b', 'border-amber-700');
          b.classList.add('text-neutral-500');
          b.setAttribute('aria-pressed', 'false');
        });

        button.classList.add('text-amber-700', 'border-b', 'border-amber-700');
        button.classList.remove('text-neutral-500');
        button.setAttribute('aria-pressed', 'true');

        renderPreview(filter);
      });
    });

    renderPreview('all');
  }
</script>

</Layout>
