---
/**
 * PhotoGallery.astro — Grille d'images responsive.
 *
 * PATTERN DE PRODUCTION : remplacer les URLs picsum par des imports locaux :
 *   import monImage from '../assets/mon-image.jpg';
 *   <Image src={monImage} alt="..." />
 * Les images importées depuis src/assets/ sont automatiquement optimisées par Astro
 * (WebP, AVIF, dimensionnement, hash de cache, lazy-loading natif).
 *
 * Pour ce scaffold, on utilise des <img> HTML standard avec picsum.photos
 * comme images de démonstration.
 */

interface GalleryImage {
  src: string;
  alt: string;
  width: number;
  height: number;
}

interface Props {
  images: GalleryImage[];
  /** Nombre de colonnes sur desktop. Par défaut : 3. */
  columns?: 2 | 3 | 4;
  /** Activer le style masonry (CSS columns). Par défaut : false. */
  masonry?: boolean;
}

const { images, columns = 3, masonry = false } = Astro.props;

const gridCols: Record<number, string> = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4',
};
---

{masonry ? (
  <!-- Mode masonry : CSS columns pour un rendu naturel sans JavaScript -->
  <div class="masonry-grid">
    <style>
      .masonry-grid { columns: 1; column-gap: 1rem; }
      @media (min-width: 640px)  { .masonry-grid { columns: 2; } }
      @media (min-width: 1024px) { .masonry-grid { columns: 3; } }
      .masonry-item { break-inside: avoid; margin-bottom: 1rem; }
    </style>
    {images.map((img) => (
      <div class="masonry-item overflow-hidden group">
        <img
          src={img.src}
          alt={img.alt}
          width={img.width}
          height={img.height}
          loading="lazy"
          decoding="async"
          class="w-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    ))}
  </div>
) : (
  <!-- Mode grille standard -->
  <div class={`grid gap-4 ${gridCols[columns]}`}>
    {images.map((img) => (
      <div class="overflow-hidden aspect-[4/3] group">
        <img
          src={img.src}
          alt={img.alt}
          width={img.width}
          height={img.height}
          loading="lazy"
          decoding="async"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    ))}
  </div>
)}
