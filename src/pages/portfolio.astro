---
/**
 * portfolio.astro — Galerie complète en style masonry.
 * Utilise PhotoGallery en mode masonry avec 12 images.
 * Les boutons de filtre sont cosmétiques (extensibles via JS si nécessaire).
 */
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';

const allImages = [
  { src: '/images/portfolio/DSC08557.jpg',  alt: 'Portrait', width: 3211, height: 4817, category: 'Portrait' },
  { src: '/images/portfolio/_DSC3143.jpg',  alt: 'Portrait', width: 4000, height: 6000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC1428.jpg',  alt: 'Portrait', width: 3376, height: 6000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC3834.jpg',  alt: 'Portrait', width: 6000, height: 4000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC3964.jpg',  alt: 'Portrait', width: 4000, height: 6000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC5194.jpg',  alt: 'Portrait', width: 4805, height: 3203, category: 'Portrait' },
  { src: '/images/portfolio/_DSC3942.jpg',  alt: 'Portrait', width: 4000, height: 6000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC6843.jpg',  alt: 'Portrait', width: 4000, height: 6000, category: 'Portrait' },
  { src: '/images/portfolio/_DSC8007.jpg',  alt: 'Portrait', width: 3991, height: 4392, category: 'Portrait' },
  { src: '/images/portfolio/_CTN5839.jpg',  alt: 'Événement', width: 6000, height: 3376, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN6190.jpg',  alt: 'Événement', width: 6000, height: 3376, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN6198.jpg',  alt: 'Événement', width: 6000, height: 4000, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN6390.jpg',  alt: 'Événement', width: 6000, height: 4000, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN6791.jpg',  alt: 'Événement', width: 3389, height: 5083, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN6835.jpg',  alt: 'Événement', width: 3503, height: 5254, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN7110.jpg',  alt: 'Événement', width: 4861, height: 3241, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN7436.jpg',  alt: 'Événement', width: 6000, height: 4000, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN8165.jpg',  alt: 'Événement', width: 6000, height: 3376, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN8171.jpg',  alt: 'Événement', width: 6000, height: 4000, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN8181.jpg',  alt: 'Événement', width: 3850, height: 2166, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN8218.jpg',  alt: 'Événement', width: 6000, height: 4000, category: 'Événementiel' },
  { src: '/images/portfolio/_CTN8263.jpg',  alt: 'Événement', width: 3098, height: 1743, category: 'Événementiel' },
];

const categories = ['Tous', 'Portrait', 'Événementiel'];
---

<Layout
  title="Portfolio"
  description="Portfolio d'Alex Diotte, photographe portrait et événementiel à Montréal, Terrebonne et sur toute la Rive-Nord du Québec."
>

  <!-- En-tête de page -->
  <section class="py-20 px-6 text-center">
    <h1 class="font-serif text-5xl sm:text-6xl font-light tracking-[0.08em] text-neutral-900 mb-4">Portfolio</h1>
    <p class="text-neutral-500 text-sm max-w-md mx-auto">
      Une sélection de moments capturés avec soin, de l'intime à l'événementiel.
    </p>
  </section>

  <!-- Filtres de catégorie (cosmétiques — extensibles avec JS) -->
  <div class="flex flex-wrap justify-center gap-6 px-6 mb-12">
    {categories.map((cat, i) => (
      <button
        class={`text-xs font-medium tracking-[0.18em] uppercase transition-colors duration-200 pb-1 ${
          i === 0
            ? 'text-amber-700 border-b border-amber-700'
            : 'text-neutral-500 hover:text-neutral-900'
        }`}
        aria-pressed={i === 0 ? 'true' : 'false'}
        data-filter={cat}
      >
        {cat}
      </button>
    ))}
  </div>

  <!-- Galerie masonry -->
  <section class="px-6 pb-24 max-w-5xl mx-auto">
    <PhotoGallery images={allImages} masonry={true} />
  </section>

  <!-- CTA bas de page -->
  <section class="py-20 px-6 text-center">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-4">
      Vous avez un projet en tête ?
    </h2>
    <p class="text-neutral-500 text-sm mb-8 max-w-sm mx-auto">
      Contactez-moi pour discuter de votre vision et obtenir un devis personnalisé.
    </p>
    <a
      href="/contact"
      class="inline-block text-xs font-medium tracking-[0.18em] uppercase text-neutral-900 border-b border-neutral-900 pb-1 hover:text-neutral-500 hover:border-neutral-500 transition-colors"
    >
      Me contacter
    </a>
  </section>


<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const items = document.querySelectorAll<HTMLElement>('[data-category]');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Mettre à jour l'état actif des boutons
      buttons.forEach(b => {
        b.classList.remove('text-amber-700', 'border-b', 'border-amber-700');
        b.classList.add('text-neutral-500');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('text-amber-700', 'border-b', 'border-amber-700');
      btn.classList.remove('text-neutral-500');
      btn.setAttribute('aria-pressed', 'true');

      // Afficher/masquer les photos
      items.forEach(item => {
        const show = filter === 'Tous' || item.dataset.category === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>

</Layout>
