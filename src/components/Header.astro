---
const navLinks = [
  { href: '/',          label: 'Accueil'   },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/services',  label: 'Services'  },
  { href: '/contact',   label: 'Contact'   },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header" class="sticky top-0 z-50 bg-white transition-[background-color,backdrop-filter,box-shadow] duration-300">
  <div class="max-w-5xl mx-auto px-6 pt-10 pb-6 text-center">

    <a href="/" class="block mb-6">
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl font-light tracking-[0.12em] uppercase text-neutral-900 leading-tight">
        Alex Diotte
      </h1>
    </a>

    <nav aria-label="Navigation principale" class="hidden md:flex items-center justify-center gap-10">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class={`text-xs font-medium tracking-[0.18em] uppercase transition-colors duration-200 ${
            currentPath === href
              ? 'text-amber-700'
              : 'text-neutral-500 hover:text-neutral-900'
          }`}
          aria-current={currentPath === href ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
      <a
        href="/#instagram"
        class="text-xs font-medium tracking-[0.18em] uppercase text-neutral-500 hover:text-neutral-900 transition-colors duration-200"
      >
        Instagram
      </a>
    </nav>

    <div class="md:hidden flex justify-center">
      <input type="checkbox" id="nav-toggle" class="sr-only peer" />
      <label
        for="nav-toggle"
        class="flex flex-col justify-center gap-[5px] w-8 h-8 cursor-pointer"
        aria-label="Ouvrir le menu de navigation"
      >
        <span class="block h-[1px] w-full bg-neutral-900 transition-all duration-300 peer-checked:rotate-45 peer-checked:translate-y-[6px] origin-center"></span>
        <span class="block h-[1px] w-full bg-neutral-900 transition-all duration-300 peer-checked:opacity-0"></span>
        <span class="block h-[1px] w-full bg-neutral-900 transition-all duration-300 peer-checked:-rotate-45 peer-checked:-translate-y-[6px] origin-center"></span>
      </label>

      <nav
        aria-label="Menu mobile"
        class="fixed top-36 left-0 right-0 bg-white border-b border-neutral-100 shadow-sm
               flex flex-col max-h-0 overflow-hidden transition-all duration-300
               peer-checked:max-h-80
               px-6 py-0 peer-checked:py-6 gap-5 z-50"
      >
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class={`text-xs font-medium tracking-[0.18em] uppercase text-center transition-colors duration-200 ${
              currentPath === href
                ? 'text-amber-700'
                : 'text-neutral-500 hover:text-neutral-900'
            }`}
            aria-current={currentPath === href ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
        <a
          href="/#instagram"
          class="text-xs font-medium tracking-[0.18em] uppercase text-center text-neutral-500 hover:text-neutral-900 transition-colors"
        >
          Instagram
        </a>
      </nav>
    </div>

  </div>

  <div class="border-b border-neutral-200"></div>
</header>

<script is:inline>
  const header = document.getElementById('site-header');

  if (header) {
    const toggleHeaderState = () => {
      const isScrolled = window.scrollY > 8;

      header.classList.toggle('bg-white/80', isScrolled);
      header.classList.toggle('backdrop-blur-md', isScrolled);
      header.classList.toggle('shadow-sm', isScrolled);

      header.classList.toggle('bg-white', !isScrolled);
    };

    toggleHeaderState();
    window.addEventListener('scroll', toggleHeaderState, { passive: true });
  }
</script>
