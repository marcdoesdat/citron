---
/**
 * ServiceCard.astro — Carte de présentation d'un forfait photographique.
 * La prop `featured` ajoute une mise en avant visuelle (bordure accent + badge).
 */
import Button from './Button.astro';

interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  icon?: string;
  featured?: boolean;
}

const { title, price, description, features, icon = '○', featured = false } = Astro.props;
---

<article
  class={`relative flex flex-col p-8 border transition-shadow duration-300 hover:shadow-md ${
    featured
      ? 'border-slate-400 shadow-sm'
      : 'border-slate-200'
  }`}
>
  <!-- Badge "Populaire" sur les forfaits mis en avant -->
  {featured && (
    <span class="absolute top-0 right-6 -translate-y-1/2 px-3 py-1 bg-neutral-900 text-white text-xs font-medium tracking-wide uppercase">
      Populaire
    </span>
  )}

  <!-- Icône et titre -->
  <div class="flex items-start gap-4 mb-6">
    <span class="text-2xl text-slate-400" aria-hidden="true">{icon}</span>
    <div>
      <h3 class={`font-serif text-2xl font-light ${featured ? 'text-neutral-900' : 'text-neutral-800'}`}>
        {title}
      </h3>
      <p class="mt-1 text-sm text-slate-500">{description}</p>
    </div>
  </div>

  <!-- Prix -->
  <div class="mb-6">
    <span class="text-3xl font-bold text-neutral-900">{price}</span>
    <span class="ml-1 text-sm text-slate-500">à partir de</span>
  </div>

  <!-- Liste des inclus -->
  <ul class="flex-1 space-y-2 mb-8">
    {features.map((feature) => (
      <li class="flex items-start gap-2 text-sm text-slate-600">
        <span class="mt-1 text-slate-400 shrink-0" aria-hidden="true">—</span>
        {feature}
      </li>
    ))}
  </ul>

  <!-- CTA -->
  <Button
    href="/contact"
    variant={featured ? 'primary' : 'secondary'}
    class="w-full"
  >
    Demander un devis
  </Button>
</article>
