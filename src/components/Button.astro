---
/**
 * Button.astro — Bouton réutilisable.
 * Rend un <a> si href est fourni, sinon un <button>.
 * Variantes : primary (fond sombre) et secondary (contour).
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  variant = 'primary',
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 px-6 py-3 text-sm font-medium tracking-wide transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2';

const variants = {
  primary:
    'bg-neutral-900 text-white hover:bg-neutral-700 focus-visible:ring-neutral-900',
  secondary:
    'border border-slate-300 text-neutral-700 bg-transparent hover:border-slate-500 hover:text-neutral-900 focus-visible:ring-slate-400',
};

const classes = `${base} ${variants[variant]} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
