---
/**
 * ServiceCard.astro — Carte de présentation d'un forfait photographique.
 * La prop `featured` ajoute une mise en avant visuelle (bordure accent + badge).
 */
import Button from './Button.astro';

interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  icon?: string;
  featured?: boolean;
  ctaLabel?: string;
}

const { title, price, description, features, icon = 'portrait', featured = false, ctaLabel = 'Demander un devis' } = Astro.props;
---

<article
  class={`relative flex flex-col p-8 border transition-shadow duration-300 hover:shadow-md ${
    featured
      ? 'border-neutral-800 shadow-md'
      : 'border-slate-200'
  }`}
>
  <!-- Badge "Populaire" sur les forfaits mis en avant -->
  {featured && (
    <span class="absolute -top-3 -right-3 px-3 py-1 rounded-full bg-neutral-900 text-white text-xs font-medium tracking-wide uppercase shadow-md ring-2 ring-white">
      Populaire
    </span>
  )}

  <!-- Icône et titre -->
  <div class="flex items-start gap-4 mb-6">
    <span class="text-slate-400 shrink-0" aria-hidden="true">
      <svg
        width="26"
        height="26"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        {icon === 'portrait' && (
          <>
            <circle cx="9" cy="9" r="4"></circle>
            <circle cx="15" cy="15" r="5"></circle>
          </>
        )}

        {icon === 'event' && (
          <>
            <path d="M12 3 21 12 12 21 3 12 12 3Z"></path>
            <path d="M12 8v8"></path>
            <path d="M8 12h8"></path>
          </>
        )}

        {icon === 'wedding' && (
          <>
            <path d="M12 3 20 12 12 21 4 12 12 3Z"></path>
          </>
        )}

        {icon === 'corporate' && (
          <>
            <path d="M4 5h16v14H4z"></path>
            <path d="M9 5v14"></path>
            <path d="M9 10h11"></path>
          </>
        )}

        {!['portrait', 'event', 'wedding', 'corporate'].includes(icon) && (
          <circle cx="12" cy="12" r="8"></circle>
        )}
      </svg>
    </span>
    <div>
      <h3 class={`font-serif text-2xl font-light ${featured ? 'text-neutral-900' : 'text-neutral-800'}`}>
        {title}
      </h3>
      <p class="mt-1 text-sm text-slate-500">{description}</p>
    </div>
  </div>

  <!-- Prix -->
  <div class="mb-6 flex items-baseline">
    <span class="text-3xl font-bold text-neutral-900">{price}</span>
    <span class="ml-1 text-sm text-slate-500">à partir de</span>
  </div>

  <!-- Liste des inclus -->
  <ul class="flex-1 space-y-2 mb-8">
    {features.map((feature) => (
      <li class="flex items-start gap-2 text-sm text-slate-600">
        <span class="mt-1 text-slate-400 shrink-0" aria-hidden="true">—</span>
        {feature}
      </li>
    ))}
  </ul>

  <!-- CTA -->
  <Button
    href="/contact"
    variant={featured ? 'primary' : 'secondary'}
    class="w-full"
  >
    {ctaLabel}
  </Button>
</article>
