---
import Layout from '../layouts/Layout.astro';
import PhotoGallery from '../components/PhotoGallery.astro';
import InstagramFeed from '../components/InstagramFeed.astro';

const previewImages = [
  { src: 'https://picsum.photos/seed/sophie1/800/600', alt: 'Portrait en lumière naturelle', width: 800, height: 600 },
  { src: 'https://picsum.photos/seed/sophie2/800/600', alt: 'Cérémonie de mariage en extérieur', width: 800, height: 600 },
  { src: 'https://picsum.photos/seed/sophie3/800/600', alt: 'Reportage événementiel en soirée', width: 800, height: 600 },
  { src: 'https://picsum.photos/seed/sophie4/800/600', alt: 'Portrait corporatif en studio', width: 800, height: 600 },
  { src: 'https://picsum.photos/seed/sophie5/800/600', alt: 'Séance portrait en plein air', width: 800, height: 600 },
  { src: 'https://picsum.photos/seed/sophie6/800/600', alt: 'Détails de décoration de mariage', width: 800, height: 600 },
];
---

<Layout
  title="Photographe Professionnelle"
  description="Alex Diotte, photographe professionnel basé à Montréal, Québec. Spécialisé en mariage, portrait, événementiel et corporatif."
>

  <!-- ═══ HERO — Image pleine page ═══════════════════════════════════════ -->
  <section class="relative z-0 h-screen w-full overflow-hidden">
    <img
      src="/hero.jpg"
      alt="Portrait photographique par Alex Diotte"
      loading="eager"
      decoding="sync"
      class="w-full h-full object-cover"
    />
  </section>

  <!-- ═══ BIO ═════════════════════════════════════════════════════════════ -->
  <section class="relative z-10 bg-white py-24 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="overflow-hidden">
        <img
          src="/alex-bio.jpg"
          alt="Alex Diotte, photographe professionnel"
          width="600"
          height="800"
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover"
        />
      </div>
      <div class="space-y-6">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 leading-tight">
          Bonjour, je suis<br/>Alex.
        </h2>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Photographe et vidéaste depuis 2016, mon histoire avec l'image a commencé par un déclic lors d'un voyage à Cuba. Si la passion est née à ce moment-là, c'est en 2020 que j'ai fait le choix de m'y consacrer à 100 %.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          J'ai d'abord plongé au cœur de la scène musicale, immortalisant l'énergie brute des foules et des artistes dans les soirées dubstep et riddim. C'est là que j'ai forgé ma signature : des images vivantes, intenses et sans artifices.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Au fil des années, j'ai élargi mon terrain de jeu. Des vlogs aux vidéoclips, en passant par des événements corporatifs et des projets scolaires, j'applique toujours la même philosophie. Mon but ? Capturer le vrai <em>vibe</em>. Que ce soit au milieu d'une foule en délire, en coulisses ou dans un moment d'intimité, je crée des images qui racontent une histoire et transmettent une émotion authentique.
        </p>
        <a
          href="/portfolio"
          class="inline-block text-xs font-medium tracking-[0.18em] uppercase text-neutral-900 border-b border-neutral-900 pb-1 hover:text-neutral-500 hover:border-neutral-500 transition-colors"
        >
          Découvrir mon travail
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ APERÇU PORTFOLIO ════════════════════════════════════════════════ -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 mb-4">Portfolio</h2>
        <p class="text-neutral-500 text-sm max-w-md mx-auto">
          Une sélection de moments capturés avec soin.
        </p>
      </div>
      <PhotoGallery images={previewImages} columns={3} />
      <div class="text-center mt-12">
        <a
          href="/portfolio"
          class="inline-block text-xs font-medium tracking-[0.18em] uppercase text-neutral-900 border-b border-neutral-900 pb-1 hover:text-neutral-500 hover:border-neutral-500 transition-colors"
        >
          Voir tout le portfolio
        </a>
      </div>
    </div>
  </section>

  <InstagramFeed posts={[
    'https://www.instagram.com/p/DTjIqmUEX8x/?img_index=1/',
    'https://www.instagram.com/p/DT_nfv8jLck/?img_index=1/',
    'https://www.instagram.com/p/DTtZNtvgXXU/?img_index=1/',
  ]} />

  <!-- ═══ CTA FINAL ═══════════════════════════════════════════════════════ -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center space-y-6">
      <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900">
        Discutons de votre projet.
      </h2>
      <p class="text-neutral-500 text-sm leading-relaxed max-w-lg mx-auto">
        Un mariage, une séance portrait ou un événement à immortaliser ? Contactez-moi pour que nous imaginions ensemble les photos qui vous ressemblent.
      </p>
      <a
        href="/contact"
        class="inline-block text-xs font-medium tracking-[0.18em] uppercase text-neutral-900 border-b border-neutral-900 pb-1 hover:text-neutral-500 hover:border-neutral-500 transition-colors"
      >
        Prendre rendez-vous
      </a>
    </div>
  </section>

</Layout>
