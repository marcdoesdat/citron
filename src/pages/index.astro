---
import Layout from '../layouts/Layout.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import SwipeGallery from '../components/SwipeGallery.astro';
import { Image } from 'astro:assets';

const allPortfolioImages = [
  { src: '/images/portfolio/DSC08557.jpg', alt: 'Portrait en lumière naturelle', category: 'Portrait' },
  { src: '/images/portfolio/_DSC3143.jpg', alt: 'Portrait urbain',               category: 'Portrait' },
  { src: '/images/portfolio/_DSC1428.jpg', alt: 'Portrait expressif',            category: 'Portrait' },
  { src: '/images/portfolio/_DSC3834.jpg', alt: 'Portrait contemplatif',         category: 'Portrait' },
  { src: '/images/portfolio/_DSC3964.jpg', alt: 'Portrait en extérieur',         category: 'Portrait' },
  { src: '/images/portfolio/_DSC5194.jpg', alt: 'Lumière de ville',              category: 'Portrait' },
  { src: '/images/portfolio/_DSC3942.jpg', alt: 'Regard naturel',                category: 'Portrait' },
  { src: '/images/portfolio/_DSC6843.jpg', alt: 'Portrait artistique',           category: 'Portrait' },
  { src: '/images/portfolio/_DSC8007.jpg', alt: 'Portrait en milieu urbain',     category: 'Portrait' },
  { src: '/images/portfolio/_CTN5839.jpg', alt: 'Ambiance événementielle',       category: 'Événement' },
  { src: '/images/portfolio/_CTN6190.jpg', alt: 'Ambiance événementielle',       category: 'Événement' },
  { src: '/images/portfolio/_CTN6198.jpg', alt: 'Moment de fête',                category: 'Événement' },
  { src: '/images/portfolio/_CTN6390.jpg', alt: 'Scène capturée en événement',   category: 'Événement' },
  { src: '/images/portfolio/_CTN6791.jpg', alt: 'Événement en salle',            category: 'Événement' },
  { src: '/images/portfolio/_CTN6835.jpg', alt: 'Reportage événementiel',        category: 'Événement' },
  { src: '/images/portfolio/_CTN7110.jpg', alt: 'Reportage événementiel',        category: 'Événement' },
  { src: '/images/portfolio/_CTN7436.jpg', alt: 'Scène capturée en événement',   category: 'Événement' },
  { src: '/images/portfolio/_CTN8165.jpg', alt: 'Ambiance festive',              category: 'Événement' },
  { src: '/images/portfolio/_CTN8171.jpg', alt: 'Scène de vie',                  category: 'Événement' },
  { src: '/images/portfolio/_CTN8181.jpg', alt: 'Portrait en lumière douce',     category: 'Événement' },
  { src: '/images/portfolio/_CTN8218.jpg', alt: 'Moment capturé',                category: 'Événement' },
  { src: '/images/portfolio/_CTN8263.jpg', alt: 'Ambiance festive',              category: 'Événement' },
];

const previewImages = allPortfolioImages;
---

<Layout
  title="Photographe Professionnelle"
  description="Alex Diotte, photographe professionnel à Montréal et sur la Rive-Nord (Terrebonne, Laval, Repentigny). Spécialisé en portrait et événementiel."
>

  <!-- ═══ HERO — Image pleine page ═══════════════════════════════════════ -->
  <section
    class="home-hero relative w-full overflow-hidden"
  >
    <Image
      src="/hero.jpg"
      alt="Portrait photographique par Alex Diotte"
      width={1920}
      height={1080}
      loading="eager"
      decoding="sync"
      fetchpriority="high"
      class="home-hero-image absolute inset-0 w-full h-full object-cover"
      style="height: 100%;"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/88 via-black/42 to-transparent"></div>
    <!-- Contenu hero -->
    <div class="home-hero-copy absolute bottom-0 left-0 right-0 p-8 sm:p-14 text-white" style="padding-bottom: max(2rem, env(safe-area-inset-bottom));">
      <h1 class="font-serif text-3xl sm:text-5xl font-semibold leading-[1.05] tracking-[0.01em] max-w-md text-balance">
        Photographe et vidéaste à Montréal
      </h1>
      <p class="site-tagline font-serif mt-3 text-white/85 leading-relaxed">
        Création visuelle pour particuliers et professionnels
      </p>
    </div>
  </section>

  <!-- ═══ APERÇU PORTFOLIO ════════════════════════════════════════════════ -->
  <section class="py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 mb-4">Portfolio</h2>
      </div>
      <SwipeGallery images={previewImages} />
      <div class="text-center mt-12">
        <a
          href="/portfolio"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Voir tout le portfolio
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BIO ═════════════════════════════════════════════════════════════ -->
  <section class="relative z-10 bg-white py-12 md:py-24 px-6">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div class="overflow-hidden">
        <Image
          src="/images/portfolio/AlexDiotteBlackandWhite.jpg"
          alt="Alex Diotte, photographe professionnel"
          width={600}
          height={800}
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-cover"
        />
      </div>
      <div class="space-y-6">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 leading-tight">
          Bonjour, je suis<br/>Alex.
        </h2>
        <p class="text-neutral-500 leading-relaxed text-sm">
          <strong>Photographe et vidéaste depuis 2016</strong>, mon histoire avec l'image a commencé par un déclic lors d'un voyage à Cuba. Si la passion est née à ce moment-là, c'est en <strong>2020</strong> que j'ai fait le choix de m'y consacrer à <strong>100 %</strong>.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          J'ai d'abord forgé mon œil au cœur de la scène musicale. Immortaliser <strong>l'énergie brute</strong> des foules dans les soirées dubstep et riddim m'a appris l'essentiel : réagir en une fraction de seconde, gérer un environnement sous pression et capturer l'instant <strong>sur le vif</strong>, sans artifices. C'est cette agilité que j'apporte aujourd'hui sur chaque plateau.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Des événements corporatifs aux projets scolaires, en passant par les vidéos promotionnelles, ma mission est de capturer le vrai <em>vibe</em>. Mon approche est <strong>100 % adaptée à vos objectifs</strong> : je peux livrer un rendu <strong>épuré et hautement professionnel</strong>, tout comme je peux déployer une <strong>direction artistique audacieuse et assumée</strong> si vous souhaitez une image de marque qui sort du lot.
        </p>
        <p class="text-neutral-500 leading-relaxed text-sm">
          Que ce soit en coulisses, lors d'un grand événement ou dans un moment d'intimité, je crée des images qui racontent votre histoire avec une <strong>émotion authentique</strong>.
        </p>
        <a
          href="/portfolio"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Découvrir mon travail
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ════════════════════════════════════════════════════════ -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900 mb-4">Services & Tarifs</h2>
        <p class="text-neutral-500 text-sm max-w-md mx-auto">
          Trois forfaits populaires pour portrait, événement et corporatif.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="service-card-item border border-neutral-200 p-8 space-y-4 cursor-pointer transition-all duration-300">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400">Portrait / Contenu Réseaux Sociaux</p>
          <h3 class="font-serif text-2xl font-light text-neutral-900">Forfait de base</h3>
          <div class="flex items-baseline gap-2">
            <p class="text-2xl font-bold text-neutral-900">150 $</p>
          </div>
          <p class="text-sm text-neutral-500">1h30, 10 photos retouchées, livraison en 5 jours.</p>
        </div>
        <div class="service-card-item border border-neutral-200 p-8 space-y-4 cursor-pointer transition-all duration-300">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400">Événement</p>
          <h3 class="font-serif text-2xl font-light text-neutral-900">Forfait 6h</h3>
          <div class="flex items-baseline gap-2">
            <p class="text-2xl font-bold text-neutral-900">450 $</p>
          </div>
          <p class="text-sm text-neutral-500">Environ 200 photos livrées, retouche incluse, livraison sous 7 jours.</p>
        </div>
        <div class="service-card-item border border-neutral-200 p-8 space-y-4 cursor-pointer transition-all duration-300">
          <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400">Corporatif & Image de marque</p>
          <h3 class="font-serif text-2xl font-light text-neutral-900">Forfait Banque d'images</h3>
          <div class="flex items-baseline gap-2">
            <p class="text-2xl font-bold text-neutral-900">550 $</p>
            <span class="text-sm text-neutral-500">à partir de</span>
          </div>
          <p class="text-sm text-neutral-500">Demi-journée (~4h), 40+ photos retouchées.</p>
        </div>
      </div>
      <div class="text-center mt-12">
        <a
          href="/services"
          class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
        >
          Voir tous les services
        </a>
      </div>
    </div>
  </section>

  <InstagramFeed posts={[
    'https://www.instagram.com/p/DN_CcZmjttY/?img_index=1',
    'https://www.instagram.com/p/DTjIqmUEX8x/?img_index=3',
    'https://www.instagram.com/p/DO9ivZYDNLo/?img_index=1',
  ]} />

  <!-- ═══ CTA FINAL ═══════════════════════════════════════════════════════ -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto text-center space-y-6">
      <h2 class="font-serif text-4xl sm:text-5xl font-light text-neutral-900">
        Discutons de votre projet.
      </h2>
      <p class="text-neutral-500 text-sm leading-relaxed max-w-lg mx-auto">
        Un mariage, une séance portrait ou un événement à immortaliser ? Contactez-moi pour que nous imaginions ensemble les photos qui vous ressemblent.
      </p>
      <a
        href="/contact"
        class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
      >
        Prendre rendez-vous
      </a>
    </div>
  </section>


<style is:global>
  .home-hero-copy h1,
  .home-hero-copy p {
    text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.6);
  }

  .home-hero-image {
    object-position: 50% 42%;
  }

  .home-hero {
    height: calc(100dvh - var(--header-height, 64px));
  }

  @media (max-width: 767px) {
    .home-hero-image {
      object-position: 52% 28%;
    }

    .home-hero {
      height: 100dvh;
      margin-top: calc(var(--header-height, 64px) * -1);
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .home-hero-image {
      object-position: 52% 36%;
    }
  }

  @supports not (height: 100dvh) {
    .home-hero {
      height: calc(100vh - var(--header-height, 64px));
    }

    @media (max-width: 767px) {
      .home-hero {
        height: 100vh;
      }
    }
  }

  .service-card-item {
    position: relative;
    overflow: hidden;
  }

  .service-card-item::after {
    content: 'en savoir plus';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.85);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .service-card-item:hover::after,
  .service-card-item.active::after {
    opacity: 1;
  }
</style>

<script>
  const serviceCards = document.querySelectorAll<HTMLDivElement>('.service-card-item');
  serviceCards.forEach(card => {
    card.addEventListener('click', () => {
      window.location.href = '/services';
    });
    card.addEventListener('touchstart', () => {
      card.classList.add('active');
    });
    card.addEventListener('touchend', () => {
      setTimeout(() => card.classList.remove('active'), 300);
    });
  });
</script>

</Layout>
