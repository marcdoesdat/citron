---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';

const portraitServices = [
  {
    title: 'Forfait de base',
    price: '150 $',
    showStartingFrom: false,
    description: 'Portrait / contenu réseaux sociaux - formule essentielle.',
    icon: 'portrait',
    featured: true,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Durée : 1h30',
      '10 photos retouchées',
      'Livraison : 5 jours',
      '1 emplacement',
    ],
  },
  {
    title: 'Forfait intermédiaire',
    price: '225 $',
    showStartingFrom: false,
    description: 'Portrait / contenu réseaux sociaux - plus de temps et de variété.',
    icon: 'portrait',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Durée : 2h30',
      '20 photos retouchées',
      'Livraison : 5 jours',
      '1-2 emplacements',
    ],
  },
  {
    title: 'Forfait ultime',
    price: '300 $',
    showStartingFrom: false,
    description: 'Portrait / contenu réseaux sociaux - expérience complète.',
    icon: 'portrait',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Durée : 3h30',
      '30 photos retouchées',
      'Livraison rapide : 2-3 jours',
      '1-3 emplacements',
    ],
  },
];

const eventServices = [
  {
    title: 'Forfait 3h',
    price: '300 $',
    showStartingFrom: false,
    description: 'Événement (anniversaire, corporatif, etc.) - format court.',
    icon: 'event',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Environ 100 photos livrées',
      'Retouche incluse',
      'Livraison sous 7 jours',
    ],
  },
  {
    title: 'Forfait 6h',
    price: '450 $',
    showStartingFrom: false,
    description: 'Événement (anniversaire, corporatif, etc.) - couverture complète.',
    icon: 'event',
    featured: true,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Environ 200 photos livrées',
      'Retouche incluse',
      'Livraison sous 7 jours',
    ],
  },
  {
    title: 'Forfait 8h',
    price: '600 $',
    showStartingFrom: false,
    description: 'Événement (anniversaire, corporatif, etc.) - journée longue.',
    icon: 'event',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Environ 300 photos livrées',
      'Retouche incluse',
      'Livraison sous 7 jours',
    ],
  },
];

const corporateServices = [
  {
    title: 'Forfait Portrait d\'affaires',
    price: '200 $',
    showStartingFrom: true,
    description: 'L\'essentiel - idéal pour les travailleurs autonomes ou la mise à jour d\'une équipe.',
    icon: 'corporate',
    featured: false,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Durée : 1h',
      'Installation d\'un studio mobile dans vos bureaux ou en extérieur',
      '5 photos retouchées en haute résolution',
      'Licence d\'utilisation commerciale incluse',
    ],
  },
  {
    title: 'Forfait Banque d\'images',
    price: '550 $',
    showStartingFrom: true,
    description: 'Le plus populaire 🌟 - idéal pour refondre un site web ou alimenter vos réseaux sociaux pendant plusieurs mois.',
    icon: 'corporate',
    featured: true,
    ctaLabel: 'Réserver ma séance',
    features: [
      'Durée : demi-journée (environ 4h)',
      'Mix de portraits de l\'équipe et de photos lifestyle en action',
      '40+ photos retouchées',
      'Licence d\'utilisation commerciale étendue',
    ],
  },
  {
    title: 'Forfait Production',
    price: 'Sur devis',
    showStartingFrom: false,
    description: 'Sur mesure - pour les grandes campagnes, le lancement de produits ou la couverture complète d\'une entreprise.',
    icon: 'corporate',
    featured: false,
    ctaLabel: 'Demander une soumission',
    features: [
      'Journée complète ou multi-jours',
      'Direction artistique complète (planification en amont)',
      'Retouches complexes (détourage, nettoyage de produits)',
      'Cession de droits complète',
    ],
  },
];

const faq = [
  {
    q: 'Vous déplacez-vous à l\'extérieur de Montréal ?',
    a: 'Oui ! Bien que je sois principalement actif dans la grande région de Montréal, je me déplace avec plaisir partout ailleurs, selon mes disponibilités. Des frais de kilométrage ou de déplacement peuvent s\'appliquer selon la distance.',
  },
  {
    q: 'Comment se déroule une séance portrait ?',
    a: 'Tout commence par une discussion pour bien cerner vos attentes et votre vision. La séance photo est dirigée avec un accompagnement sur les poses et l\'éclairage. Finalement, on fait la sélection et la retouche minutieuse des meilleures photos.',
  },
  {
    q: 'Puis-je ajouter des filtres aux photos reçues ?',
    a: 'Chaque image que je vous livre est le résultat d\'un travail de retouche méticuleux qui reflète mon identité photographique. Afin de préserver cette intégrité artistique et la qualité optimale des images, je demande de ne pas appliquer de filtres supplémentaires (comme ceux d\'Instagram) par la suite.',
  },
];
---

<Layout
  title="Services & Tarifs"
  description="Forfaits portrait, événement, corporatif et contenu réseaux sociaux à Montréal et sur la Rive-Nord."
>

  <!-- En-tête -->
  <section class="py-20 px-6 text-center">
    <h1 class="font-serif text-5xl sm:text-6xl font-light tracking-[0.08em] text-neutral-900 mb-4">Services & Tarifs</h1>
    <p class="text-neutral-500 text-sm max-w-md mx-auto leading-relaxed">
      Portrait, événement, corporatif et contenu réseaux sociaux : des forfaits clairs, flexibles et adaptés à vos objectifs.
    </p>
  </section>

  <!-- Grille Portrait / Réseaux sociaux -->
  <section class="px-6 pb-16 max-w-5xl mx-auto">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-8 text-center">Portrait / Contenu Réseaux Sociaux</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {portraitServices.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </section>

  <!-- Grille Événement -->
  <section class="px-6 pb-16 max-w-5xl mx-auto">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-8 text-center">Événement</h2>
    <p class="text-neutral-500 text-sm max-w-xl mx-auto text-center mb-8">
      Anniversaire, corporatif et autres événements.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {eventServices.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </section>

  <!-- Grille Corporatif -->
  <section class="px-6 pb-16 max-w-5xl mx-auto">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-4 text-center">Corporatif & Image de marque</h2>
    <p class="text-neutral-500 text-sm max-w-2xl mx-auto text-center mb-8">
      Pour les professionnels, les PME et la création de banques d'images.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {corporateServices.map((service) => (
        <ServiceCard {...service} />
      ))}
    </div>
  </section>

  <!-- Extras -->
  <div class="max-w-5xl mx-auto px-6 mb-16 border-t border-slate-100 pt-8">
    <h2 class="font-serif text-2xl font-light text-neutral-900 mb-4 text-center">Extras 🍋</h2>
    <ul class="text-sm text-slate-500 max-w-2xl mx-auto space-y-2">
      <li>+100 $ / heure supplémentaire</li>
      <li>+250 $ pour montage vidéo récap (1-2 min)</li>
      <li>+75 $ pour livraison rapide (2-3 jours)</li>
      <li>Imprimerie disponible sur demande</li>
      <li>50¢ / km en dehors de Montréal et Rive-Nord</li>
    </ul>
  </div>

  <!-- Section FAQ rapide -->
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-10 text-center">Questions fréquentes</h2>

      <div class="space-y-6">
        {faq.map(({ q, a }) => (
          <div class="border-b border-neutral-100 pb-6">
            <h3 class="font-medium text-neutral-900 mb-2">{q}</h3>
            <p class="text-sm text-neutral-500 leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 text-center">
    <h2 class="font-serif text-3xl sm:text-4xl font-light text-neutral-900 mb-4">
      Prêt·e à commencer ?
    </h2>
    <p class="text-neutral-500 text-sm mb-8 max-w-sm mx-auto">
      Décrivez votre projet et je vous répondrai dans les 24h avec une proposition sur mesure.
    </p>
    <a
      href="/contact"
      class="flex w-fit mx-auto items-center justify-center px-6 py-3 min-h-11 text-xs font-semibold tracking-[0.14em] uppercase text-neutral-900 border border-neutral-900 rounded-sm hover:bg-neutral-900 hover:text-white transition-colors duration-200"
    >
      Demander un devis gratuit
    </a>
  </section>

</Layout>
